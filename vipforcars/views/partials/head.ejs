<!-- Schema.org Markup (Tells Google exactly what your business is ) -->
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "AutoRental",
    "name": "VIP For Cars",
    "image": "https://www.vipforcars.onrender.com/images/og-image.jpg",
    "@id": "https://www.vipforcars.onrender.com/",
    "url": "https://www.vipforcars.onrender.com/",
    "telephone": "+201111036937",
    "priceRange": "$$$",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Cairo",
      "addressLocality": "Cairo",
      "addressRegion": "Cairo Governorate",
      "addressCountry": "EG"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 30.0444,
      "longitude": 31.2357
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday"
      ],
