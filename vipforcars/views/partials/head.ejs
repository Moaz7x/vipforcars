<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<!-- Primary Meta Tags -->
<title><%= __('SEO_TITLE') %></title>
<meta name="title" content="<%= __('SEO_TITLE') %>" />
<meta name="description" content="<%= __('SEO_DESC') %>" />
<meta name="keywords" content="<%= __('SEO_KEYWORDS') %>" />
<meta name="author" content="VIP For Cars" />
<meta name="robots" content="index, follow" />
<meta name="language" content="<%= lang %>" />
<meta property="og:locale" content="<%= lang === 'en' ? 'en_US' : lang === 'ar' ? 'ar_EG' : lang %>">

<!-- Open Graph / Facebook / WhatsApp -->
<meta property="og:type" content="website" />
<meta property="og:url" content="https://www.vipforcars.onrender.com/" />
<meta property="og:title" content="<%= __('SEO_TITLE' ) %>" />
<meta property="og:description" content="<%= __('SEO_DESC') %>" />
<!-- Note: You should upload a nice 1200x630 image of your best car to your public/images folder and name it og-image.jpg -->
<meta
  property="og:image"
  content="https://www.vipforcars.onrender.com/images/og-image.jpg"
/>

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content="https://www.vipforcars.onrender.com/" />
<meta property="twitter:title" content="<%= __('SEO_TITLE' ) %>" />
<meta property="twitter:description" content="<%= __('SEO_DESC') %>" />
<meta
  property="twitter:image"
  content="https://www.vipforcars.onrender.com/images/og-image.jpg"
/>

