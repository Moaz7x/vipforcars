<link rel="alternate" hreflang="ru" href="https://www.vipforcars.onrender.com/lang/ru" />
<link rel="alternate" hreflang="tr" href="https://www.vipforcars.onrender.com/lang/tr" />
<link rel="alternate" hreflang="zh" href="https://www.vipforcars.onrender.com/lang/zh" />
