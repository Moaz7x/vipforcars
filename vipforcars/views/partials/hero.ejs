<header
  class="relative h-screen flex items-center justify-center text-center overflow-hidden"
>
  <!-- Background Image & Dynamic Overlays -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?q=80&w=2670&auto=format&fit=crop"
      alt="Luxury Car"
      class="w-full h-full object-cover opacity-80 dark:opacity-40 transition-opacity duration-700"
    />
    <!-- Adapts to Light/Dark Mode -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-light-50 via-light-50/60 dark:from-dark-900 dark:via-dark-900/80 to-transparent transition-colors duration-500"
    ></div>
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_transparent_0%,_rgba(252,250,245,0.5 )_100%)] dark:bg-[radial-gradient(ellipse_at_center,_transparent_0%,_rgba(10,10,10,0.8)_100%)] transition-colors duration-500"
    ></div>
  </div>

  <!-- Decorative Glow -->
  <div
    class="absolute inset-0 z-0 flex items-center justify-center pointer-events-none"
  >
    <div
      class="w-[800px] h-[800px] rounded-full bg-gradient-to-br from-gold-500/20 to-transparent blur-[120px]"
    ></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl px-6 fade-in mt-16">
    <div class="mb-8">
      <span
        class="inline-block px-6 py-2.5 rounded-full glass-card text-xs font-bold tracking-[0.3em] text-gray-800 dark:text-gray-300 uppercase shadow-sm"
      >
        <%= __('HERO_SUBTITLE') %>
      </span>
    </div>

    <h1
      class="text-5xl md:text-7xl lg:text-8xl font-serif font-bold mb-6 leading-tight text-gray-900 dark:text-white drop-shadow-lg"
    >
      <%= __('HERO_TITLE') %>
      <span class="gold-gradient"><%= __('HERO_LUXURY') %></span>
    </h1>

    <p
      class="text-lg md:text-xl text-gray-700 dark:text-gray-300 mb-12 max-w-2xl mx-auto leading-relaxed font-medium drop-shadow-md"
    >
      <%= __('HERO_DESC') %>
    </p>

    <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
      <a
        href="#fleet"
        class="btn-gold text-black font-bold px-12 py-4 rounded-full text-sm tracking-[0.2em] uppercase w-full sm:w-auto"
      >
        <%= __('HERO_BTN') %>
      </a>
      <a
        href="#services"
        class="glass-card px-12 py-4 rounded-full text-gray-900 dark:text-white font-bold text-sm tracking-[0.2em] uppercase hover:border-gold-500 hover:text-gold-600 dark:hover:text-gold-400 transition-all duration-300 w-full sm:w-auto"
      >
        <%= __('HERO_SERVICES_BTN') %>
      </a>
    </div>

    <!-- Stats -->
    <!-- Stats -->
    <div
      class="mt-16 md:mt-24 flex flex-wrap justify-center items-center gap-4 md:gap-16 glass-card py-4 md:py-6 px-4 md:px-8 rounded-3xl w-full sm:w-auto mx-auto"
    >
      <div class="text-center px-2">
        <div class="text-2xl md:text-4xl font-serif font-bold gold-gradient">
          12+
        </div>
        <div
          class="text-[10px] md:text-xs text-gray-600 dark:text-gray-400 mt-1 md:mt-2 tracking-widest uppercase font-semibold"
        >
          <%= __('STAT_YEARS') %>
        </div>
      </div>
      <div class="h-8 md:h-12 w-px bg-gray-300 dark:bg-gray-700"></div>
      <div class="text-center px-2">
        <div class="text-2xl md:text-4xl font-serif font-bold gold-gradient">
          15K+
        </div>
        <div
          class="text-[10px] md:text-xs text-gray-600 dark:text-gray-400 mt-1 md:mt-2 tracking-widest uppercase font-semibold"
        >
          <%= __('STAT_CLIENTS') %>
        </div>
      </div>
      <div class="h-8 md:h-12 w-px bg-gray-300 dark:bg-gray-700"></div>
      <div class="text-center px-2">
        <div class="text-2xl md:text-4xl font-serif font-bold gold-gradient">
          50+
        </div>
        <div
          class="text-[10px] md:text-xs text-gray-600 dark:text-gray-400 mt-1 md:mt-2 tracking-widest uppercase font-semibold"
        >
          <%= __('STAT_VEHICLES') %>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10">
    <div
      class="flex flex-col items-center gap-2 text-gray-500 dark:text-gray-400 animate-bounce"
    >
      <span class="text-xs tracking-widest uppercase font-semibold"
        ><%= __('SCROLL') %></span
      >
      <svg
        class="w-5 h-5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"
        ></path>
      </svg>
    </div>
  </div>
</header>
