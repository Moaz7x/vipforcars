<section id="fleet" class="py-24 lg:py-32 px-6 relative noise-bg overflow-hidden">
    <div class="absolute top-20 left-10 w-96 h-96 rounded-full bg-gold-500/5 blur-[100px] pointer-events-none"></div>
    
    <div class="max-w-7xl mx-auto relative z-10">
        <div class="text-center mb-16 fade-in">
            <span class="text-sm tracking-[0.3em] text-gray-500 dark:text-gray-400 uppercase"><%= __('FLEET_SUBTITLE') %></span>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold mb-6 text-gray-900 dark:text-white mt-4"><%= __('FLEET_TITLE') %></h2>
            <div class="w-20 h-1 bg-gradient-to-r from-gold-600 via-gold-500 to-gold-400 mx-auto"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% if (vehicles.length === 0) { %>
                <p class="text-center text-gray-500 dark:text-gray-400 col-span-full py-20 font-medium"><%= __('FLEET_EMPTY') %></p>
            <% } %>

            <% vehicles.forEach((vehicle, index) => { %>
            <div class="group fade-in" style="transition-delay: 100ms">
                <div class="glass-card rounded-3xl overflow-hidden transition-all duration-500 hover:border-gold-500/50 hover:-translate-y-2 hover:shadow-2xl hover:shadow-gold-500/10 h-full flex flex-col">
                    
                    <!-- Image Container -->
                    <div class="relative h-64 lg:h-72 overflow-hidden bg-gray-200 dark:bg-dark-800">
                        <img src="<%= vehicle.image_url %>" alt="<%= vehicle.name %>" class="w-full h-full object-cover transition-transform duration-[1.5s] group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
                        <div class="absolute top-4 right-4">
                            <span class="px-4 py-1.5 rounded-full text-xs font-bold tracking-wider bg-white/90 dark:bg-black/70 backdrop-blur-md text-gold-600 dark:text-gold-400 shadow-lg">
                                <%= vehicle.category %>
                            </span>
                        </div>
                    </div>
                    
                    <!-- Content -->
                    <div class="p-8 flex flex-col flex-grow">
                        <div class="mb-6 flex-grow">
                            <h3 class="text-2xl font-serif font-bold mb-3 text-gray-900 dark:text-white group-hover:text-gold-600 dark:group-hover:text-gold-400 transition-colors duration-300"><%= vehicle.name %></h3>
                            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed font-medium"><%= lang === 'ar' ? vehicle.desc_ar : vehicle.desc_en %></p>
                        </div>
                        
                        <!-- Specs -->
                        <div class="grid grid-cols-2 gap-4 mb-8 pt-6 border-t border-gray-200 dark:border-white/10">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-gold-500/10 flex items-center justify-center text-gold-600 dark:text-gold-400">👤</div>
                                <div>
                                    <div class="text-[10px] text-gray-500 dark:text-gray-400 uppercase tracking-widest font-bold"><%= __('FLEET_SEATS') %></div>
                                    <div class="text-gray-900 dark:text-white font-bold"><%= vehicle.passengers %></div>
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-gold-500/10 flex items-center justify-center text-gold-600 dark:text-gold-400">🧳</div>
                                <div>
                                    <div class="text-[10px] text-gray-500 dark:text-gray-400 uppercase tracking-widest font-bold"><%= __('FLEET_BAGS') %></div>
                                    <div class="text-gray-900 dark:text-white font-bold"><%= vehicle.luggage %></div>
                                </div>
                            </div>
                        </div>

                        <a href="#contact" class="block w-full text-center btn-gold text-black font-bold py-4 rounded-xl text-xs tracking-[0.2em] uppercase">
                            <%= __('FLEET_RESERVE') %>
                        </a>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</section>
