<section id="services" class="py-24 lg:py-32 px-6 relative noise-bg overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-gold-500/5 blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="text-center mb-16 fade-in">
      <span class="text-sm tracking-[0.3em] text-gray-500 dark:text-gray-400 uppercase"><%= __('SERVICES_SUBTITLE') %></span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold mb-6 text-gray-900 dark:text-white mt-4"><%= __('SERVICES_TITLE') %></h2>
      <div class="w-20 h-1 bg-gradient-to-r from-gold-600 via-gold-500 to-gold-400 mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% const services = [
        { icon: '✈️', title: __('SRV1_TITLE'), desc: __('SRV1_DESC'), delay: '0ms' },
        { icon: '💼', title: __('SRV2_TITLE'), desc: __('SRV2_DESC'), delay: '100ms' },
        { icon: '💍', title: __('SRV3_TITLE'), desc: __('SRV3_DESC'), delay: '200ms' }
      ]; %>

      <% services.forEach(srv => { %>
      <div class="fade-in" style="transition-delay: 100ms">
        <div class="glass-card rounded-3xl p-10 transition-all duration-500 group hover:border-gold-500/50 hover:-translate-y-3 hover:shadow-2xl hover:shadow-gold-500/10 h-full">
          <div class="w-20 h-20 mx-auto rounded-2xl bg-gold-500/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-500 border border-gold-500/20">
            <div class="text-4xl drop-shadow-lg"><%= srv.icon %></div>
          </div>
          <h3 class="text-2xl font-serif font-bold mb-4 text-center text-gray-900 dark:text-white group-hover:text-gold-600 dark:group-hover:text-gold-400 transition-colors duration-300"><%= srv.title %></h3>
          <p class="text-gray-600 dark:text-gray-400 text-center leading-relaxed font-medium"><%= srv.desc %></p>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>
