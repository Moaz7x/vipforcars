    >
      <span>&copy; 2026 <%= __('FOOTER_RIGHTS') %></span>
      <a href="/admin/login" class="hover:text-gold-500 transition-colors"
        ><%= __('FOOTER_ADMIN') %></a
      >
    </div>
  </div>
</footer>
