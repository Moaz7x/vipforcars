<footer
  class="py-16 border-t border-gray-200 dark:border-white/5 relative noise-bg bg-white/30 dark:bg-black/30 backdrop-blur-md"
>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 rounded-full bg-gradient-to-br from-gold-600 to-gold-400 flex items-center justify-center text-black font-bold shadow-lg shadow-gold-500/30"
          >
            V
          </div>
          <div
            class="text-2xl font-serif font-bold tracking-[0.2em] text-gray-900 dark:text-white"
          >
            VIP<span class="gold-gradient">FORCARS</span>
          </div>
        </div>
        <p
          class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed font-medium max-w-sm"
        >
          <%= __('FOOTER_DESC') %>
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4
          class="text-gray-900 dark:text-white font-bold mb-6 tracking-widest uppercase text-sm"
        >
          <%= __('FOOTER_LINKS') %>
        </h4>
        <ul
          class="space-y-4 text-gray-600 dark:text-gray-400 text-sm font-medium"
        >
          <li>
            <a
              href="#fleet"
              class="hover:text-gold-600 dark:hover:text-gold-400 transition-colors flex items-center gap-2 group"
              ><span
                class="w-1.5 h-1.5 bg-gold-500 rounded-full opacity-0 group-hover:opacity-100 transition-opacity"
              ></span
              ><%= __('NAV_FLEET') %></a
            >
          </li>
          <li>
            <a
              href="#services"
              class="hover:text-gold-600 dark:hover:text-gold-400 transition-colors flex items-center gap-2 group"
              ><span
                class="w-1.5 h-1.5 bg-gold-500 rounded-full opacity-0 group-hover:opacity-100 transition-opacity"
              ></span
              ><%= __('NAV_SERVICES') %></a
            >
          </li>
          <li>
            <a
              href="#contact"
              class="hover:text-gold-600 dark:hover:text-gold-400 transition-colors flex items-center gap-2 group"
              ><span
                class="w-1.5 h-1.5 bg-gold-500 rounded-full opacity-0 group-hover:opacity-100 transition-opacity"
              ></span
              ><%= __('NAV_BOOK') %></a
            >
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4
          class="text-gray-900 dark:text-white font-bold mb-6 tracking-widest uppercase text-sm"
        >
          <%= __('FOOTER_CONTACT') %>
        </h4>
        <ul
          class="space-y-4 text-gray-600 dark:text-gray-400 text-sm font-medium"
        >
          <li
            dir="ltr"
            class="<%= lang === 'ar' ? 'text-right' : '' %> flex items-center gap-3"
          >
            <span
              class="w-8 h-8 rounded-full bg-gold-500/10 flex items-center justify-center text-gold-600 dark:text-gold-400"
              >📞</span
            >
            <a
              href="tel:+201111036937"
              class="hover:text-gold-600 dark:hover:text-gold-400 transition-colors"
              >+20 1111036937</a
            >
          </li>
          <li
            dir="ltr"
            class="<%= lang === 'ar' ? 'text-right' : '' %> flex items-center gap-3"
          >
            <span
              class="w-8 h-8 rounded-full bg-gold-500/10 flex items-center justify-center text-gold-600 dark:text-gold-400"
              >✉️</span
            >
            <a
              href="mailto:reservations@vipforcars.com"
              class="hover:text-gold-600 dark:hover:text-gold-400 transition-colors"
              >reservations@vipforcars.com</a
            >
          </li>
          <li class="flex items-center gap-3">
            <span
              class="w-8 h-8 rounded-full bg-gold-500/10 flex items-center justify-center text-gold-600 dark:text-gold-400"
