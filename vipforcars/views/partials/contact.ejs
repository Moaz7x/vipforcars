<section id="contact" class="py-24 lg:py-32 px-6 relative noise-bg overflow-hidden">
  <!-- Decorative Glow -->
  <div class="absolute top-20 right-10 w-96 h-96 rounded-full bg-gold-500/10 blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-20 left-10 w-96 h-96 rounded-full bg-gold-500/10 blur-[100px] pointer-events-none"></div>
  
  <div class="max-w-6xl mx-auto relative z-10">
    
    <!-- Header -->
    <div class="text-center mb-16 fade-in">
      <span class="text-sm tracking-[0.3em] text-gray-500 dark:text-gray-400 uppercase"><%= __('CONTACT_SUBTITLE') %></span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold mb-6 text-gray-900 dark:text-white mt-4"><%= __('CONTACT_TITLE') %></h2>
      <div class="w-20 h-1 bg-gradient-to-r from-gold-600 via-gold-500 to-gold-400 mx-auto mb-6"></div>
      <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto"><%= __('CONTACT_SUB') %></p>
    </div>

    <form id="bookingForm" class="glass-card p-8 lg:p-12 rounded-3xl fade-in w-full shadow-2xl">
      
      <!-- 1. Trip Details -->
      <div class="mb-10">
        <h3 class="text-xl font-serif font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-3">
          <span class="w-8 h-8 rounded-full bg-gold-500/20 flex items-center justify-center text-gold-600 dark:text-gold-400 text-sm">1</span>
          <%= __('STEP_TRIP_DETAILS') %>
        </h3>
        
       <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <% const inputs = [
            { 
              id: 'province', 
              type: 'select', 
              label: __('FORM_PROVINCE'), 
              options: [
                'Cairo / القاهرة',
                'Giza / الجيزة',
                'Alexandria / الإسكندرية',
                'Aswan / أسوان',
                'Asyut / أسيوط',
                'Beheira / البحيرة',
                'Beni Suef / بني سويف',
                'Dakahlia / الدقهلية',
                'Damietta / دمياط',
                'Faiyum / الفيوم',
                'Gharbia / الغربية',
                'Ismailia / الإسماعيلية',
                'Kafr El Sheikh / كفر الشيخ',
                'Luxor / الأقصر',
                'Matrouh / مطروح',
                'Minya / المنيا',
                'Monufia / المنوفية',
                'New Valley / الوادي الجديد',
                'North Sinai / شمال سيناء',
                'Port Said / بورسعيد',
                'Qalyubia / القليوبية',
                'Qena / قنا',
                'Red Sea / البحر الأحمر',
                'Sharqia / الشرقية',
                'Sohag / سوهاج',
                'South Sinai / جنوب سيناء',
                'Suez / السويس'
              ] 
            },
            { id: 'departure', type: 'text', label: __('FORM_DEPARTURE') },
            { id: 'destination', type: 'text', label: __('FORM_DESTINATION') },
            { id: 'date', type: 'date', label: __('FORM_DATE') },
            { id: 'time', type: 'time', label: __('FORM_TIME') }
          ]; %>
          
          <% inputs.forEach(input => { %>
          <div class="group">
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2"><%= input.label %></label>
            <% if(input.type === 'select') { %>
              <select id="<%= input.id %>" class="w-full bg-white/50 dark:bg-black/30 border border-gray-200 dark:border-white/10 rounded-2xl p-4 text-gray-900 dark:text-white focus:ring-2 focus:ring-gold-500 focus:border-transparent transition-all outline-none appearance-none shadow-inner">
                <option value="" disabled selected><%= input.label %></option>
                <% input.options.forEach(opt => { %><option value="<%= opt %>"><%= opt %></option><% }) %>
              </select>
            <% } else { %>
              <input type="<%= input.type %>" id="<%= input.id %>" class="w-full bg-white/50 dark:bg-black/30 border border-gray-200 dark:border-white/10 rounded-2xl p-4 text-gray-900 dark:text-white focus:ring-2 focus:ring-gold-500 focus:border-transparent transition-all outline-none [color-scheme:light] dark:[color-scheme:dark] shadow-inner" />
            <% } %>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Toggles (Trip Type, Direction, Bags) -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10 pt-8 pb-8 border-y border-gray-200 dark:border-white/10">
        <% const toggles = [
          { name: 'trip_type', label: __('FORM_TRIP_TYPE'), opts: [__('FORM_TRIP_INSIDE'), __('FORM_TRIP_OUTSIDE')] },
          { name: 'direction', label: __('FORM_DIRECTION'), opts: [__('FORM_DIR_ONEWAY'), __('FORM_DIR_ROUND')] },
          { name: 'bags', label: __('FORM_BAGS'), opts: [__('FORM_YES'), __('FORM_NO')] }
        ]; %>
        
        <% toggles.forEach(toggle => { %>
        <div>
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4"><%= toggle.label %></label>
          <div class="flex gap-4">
            <% toggle.opts.forEach((opt, idx) => { %>
            <label class="flex-1 cursor-pointer">
              <input type="radio" name="<%= toggle.name %>" value="<%= opt %>" class="peer sr-only" <%= idx === 0 ? 'checked' : '' %> />
              <div class="text-center py-3.5 rounded-2xl border border-gray-200 dark:border-white/10 bg-white/50 dark:bg-black/30 text-gray-600 dark:text-gray-400 peer-checked:border-gold-500 peer-checked:text-gold-600 dark:peer-checked:text-gold-400 peer-checked:bg-gold-500/10 transition-all font-medium text-sm shadow-sm">
                <%= opt %>
              </div>
            </label>
            <% }) %>
          </div>
        </div>
        <% }) %>
      </div>

      <!-- 2. Car Selection -->
      <div class="mb-10">
        <h3 class="text-xl font-serif font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-3">
          <span class="w-8 h-8 rounded-full bg-gold-500/20 flex items-center justify-center text-gold-600 dark:text-gold-400 text-sm">2</span>
          <%= __('FORM_CAR_TYPE') %>
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          <% const carTypes = [
            { value: __('CAR_SEDAN'), img: '/images/sedan.png' },
            { value: __('CAR_SUV_MODERN'), img: '/images/suv.png' },
            { value: __('CAR_FAMILY_VIP'), img: '/images/vip.png' },
            { value: __('CAR_SUV_FAMILY'), img: '/images/suv7.png' },
            { value: __('CAR_H1'), img: '/images/h18.png' },
            { value: __('CAR_MICROBUS'), img: '/images/microbus.png' }
          ]; %>
          <% carTypes.forEach((car, idx) => { %>
            <label class="cursor-pointer relative group">
              <input type="radio" name="car_type" value="<%= car.value %>" class="peer sr-only" required <%= idx === 0 ? 'checked' : '' %> />
              <div class="h-full rounded-2xl border-2 border-dashed border-gray-300 dark:border-white/10 bg-white/50 dark:bg-black/30 p-4 group-hover:border-gold-500/50 peer-checked:border-solid peer-checked:border-gold-500 peer-checked:bg-gold-500/10 transition-all text-center flex flex-col items-center justify-between shadow-sm">
                <img src="<%= car.img %>" class="h-16 w-full object-contain mb-3 drop-shadow-lg group-hover:scale-110 transition-transform duration-300" />
                <span class="block text-xs font-bold text-gray-600 dark:text-gray-300 peer-checked:text-gold-600 dark:peer-checked:text-gold-400"><%= car.value %></span>
              </div>
            </label>
          <% }) %>
        </div>
      </div>

      <!-- 3. Customer Details -->
      <div class="mb-10">
        <h3 class="text-xl font-serif font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-3">
          <span class="w-8 h-8 rounded-full bg-gold-500/20 flex items-center justify-center text-gold-600 dark:text-gold-400 text-sm">3</span>
          <%= __('STEP_YOUR_DETAILS') %>
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="group">
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2"><%= __('FORM_NAME') %></label>
            <input type="text" id="customer_name" class="w-full bg-white/50 dark:bg-black/30 border border-gray-200 dark:border-white/10 rounded-2xl p-4 text-gray-900 dark:text-white focus:ring-2 focus:ring-gold-500 focus:border-transparent transition-all outline-none shadow-inner" />
          </div>
          <div class="group">
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2"><%= __('FORM_PHONE') %></label>
            <input type="tel" id="customer_phone" class="w-full bg-white/50 dark:bg-black/30 border border-gray-200 dark:border-white/10 rounded-2xl p-4 text-gray-900 dark:text-white focus:ring-2 focus:ring-gold-500 focus:border-transparent transition-all outline-none shadow-inner" />
          </div>
          <div class="group">
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2"><%= __('FORM_BACKUP_PHONE') %></label>
            <input type="tel" id="backup_phone" class="w-full bg-white/50 dark:bg-black/30 border border-gray-200 dark:border-white/10 rounded-2xl p-4 text-gray-900 dark:text-white focus:ring-2 focus:ring-gold-500 focus:border-transparent transition-all outline-none shadow-inner" />
          </div>
          <div class="group">
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2"><%= __('FORM_PASSENGERS') %></label>
            <input type="number" id="passengers" min="1" value="1" class="w-full bg-white/50 dark:bg-black/30 border border-gray-200 dark:border-white/10 rounded-2xl p-4 text-gray-900 dark:text-white focus:ring-2 focus:ring-gold-500 focus:border-transparent transition-all outline-none shadow-inner" />
          </div>
        </div>
      </div>

      <!-- 4. Notes & Checkboxes -->
      <div class="mb-10">
        <div class="group mb-6">
          <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2"><%= __('FORM_NOTES') %></label>
          <textarea id="notes" rows="3" placeholder="<%= __('FORM_NOTES_PH') %>" class="w-full bg-white/50 dark:bg-black/30 border border-gray-200 dark:border-white/10 rounded-2xl p-4 text-gray-900 dark:text-white focus:ring-2 focus:ring-gold-500 focus:border-transparent transition-all outline-none resize-none shadow-inner placeholder-gray-400 dark:placeholder-gray-600"></textarea>
        </div>

        <div class="flex flex-col gap-4">
          <label class="flex items-center cursor-pointer group w-fit">
            <input type="checkbox" id="airport" value="Yes" class="w-5 h-5 accent-gold-500 bg-white/50 dark:bg-black/30 border-gray-300 dark:border-white/10 rounded focus:ring-gold-500 cursor-pointer" />
            <span class="mx-3 text-sm font-medium text-gray-600 dark:text-gray-400 group-hover:text-gray-900 dark:group-hover:text-white transition"><%= __('FORM_AIRPORT') %></span>
          </label>
          <label class="flex items-center cursor-pointer group w-fit">
            <input type="checkbox" id="terms" required class="w-5 h-5 accent-gold-500 bg-white/50 dark:bg-black/30 border-gray-300 dark:border-white/10 rounded focus:ring-gold-500 cursor-pointer" />
            <span class="mx-3 text-sm font-medium text-gray-600 dark:text-gray-400 group-hover:text-gray-900 dark:group-hover:text-white transition"><%= __('FORM_TERMS') %></span>
          </label>
        </div>
      </div>

      <!-- Submit Button -->
      <button type="button" onclick="sendToWhatsApp()" class="w-full btn-gold text-black font-bold py-5 rounded-2xl text-sm tracking-[0.2em] uppercase flex justify-center items-center gap-3">
        <span><%= __('FORM_SUBMIT_COST') %></span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </button>
    </form>
  </div>
</section>
