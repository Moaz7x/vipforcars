<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VIP Admin Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        gold: { 400: '#e8c56a', 500: '#d4af37', 600: '#a88b2c' },
                        dark: { 900: '#0a0a0a', 800: '#121212', 700: '#1a1a1a' }
                    },
                    fontFamily: { sans: ['Montserrat', 'sans-serif'], serif: ['Playfair Display', 'serif'] }
                }
            }
        }
    </script>
    <style>
        body { transition: background-color 0.5s ease, color 0.5s ease; }
        .glass-panel { background: rgba(255, 255, 255, 0.7 ); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.3); }
        .dark .glass-panel { background: rgba(26, 26, 26, 0.6); border: 1px solid rgba(255, 255, 255, 0.05); }
        .gold-gradient-text { background: linear-gradient(135deg, #a88b2c 0%, #d4af37 50%, #e8c56a 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
        .fade-in-up { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; transform: translateY(20px); }
        @keyframes fadeInUp { to { opacity: 1; transform: translateY(0); } }
        .delay-100 { animation-delay: 100ms; }
        .delay-200 { animation-delay: 200ms; }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #d4af37; border-radius: 4px; }
        .dark ::-webkit-scrollbar-thumb { background: #a88b2c; }
        
        /* Tab Transitions */
        .tab-content { display: none; opacity: 0; transition: opacity 0.4s ease; }
        .tab-content.active { display: block; opacity: 1; }
    </style>
</head>
<body class="bg-gray-50 dark:bg-dark-900 text-gray-800 dark:text-gray-200 font-sans antialiased selection:bg-gold-500 selection:text-white">

    <div id="mobileOverlay" onclick="toggleSidebar()" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 hidden lg:hidden transition-opacity opacity-0"></div>

    <!-- Sidebar -->
    <aside id="sidebar" class="fixed top-0 left-0 h-full w-72 glass-panel shadow-2xl z-50 transform -translate-x-full lg:translate-x-0 transition-transform duration-500 ease-in-out flex flex-col border-r border-gray-200 dark:border-white/5">
        <div class="p-8 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-gold-600 to-gold-400 flex items-center justify-center text-black font-bold text-xl shadow-lg shadow-gold-500/30">V</div>
                <h2 class="text-2xl font-serif font-bold tracking-widest dark:text-white">VIP<span class="gold-gradient-text">ADMIN</span></h2>
            </div>
            <button onclick="toggleSidebar()" class="lg:hidden text-gray-500 dark:text-gray-400 hover:text-gold-500">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <nav class="flex-1 px-6 space-y-2 overflow-y-auto">
            <!-- Tab Buttons -->
            <button onclick="switchTab('fleet')" id="tab-btn-fleet" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl bg-gold-500/10 text-gold-600 dark:text-gold-400 font-medium border border-gold-500/20 transition-all text-left">
                🚗 Fleet & Bookings
            </button>
            <button onclick="switchTab('articles')" id="tab-btn-articles" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-gray-600 dark:text-gray-400 font-medium hover:bg-gray-100 dark:hover:bg-white/5 transition-all text-left">
                📝 Articles & News
            </button>
        </nav>

        <div class="p-6 border-t border-gray-200 dark:border-white/5">
            <div class="flex items-center gap-3 mb-6 px-2">
                <div class="w-10 h-10 rounded-full bg-gray-200 dark:bg-dark-700 flex items-center justify-center text-gray-600 dark:text-gray-300 font-bold"><%= admin.username.charAt(0).toUpperCase() %></div>
                <div>
                    <p class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider">Logged in as</p>
                    <p class="text-sm font-bold dark:text-white"><%= admin.username %></p>
                </div>
            </div>
            <a href="/api/auth/logout" class="flex items-center justify-center gap-2 w-full py-3 rounded-xl bg-red-500/10 text-red-600 dark:text-red-400 font-semibold hover:bg-red-500 hover:text-white transition-all duration-300">
                Secure Logout
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 lg:ml-72 flex flex-col h-screen overflow-hidden relative">
        
        <header class="glass-panel sticky top-0 z-30 px-6 py-4 flex justify-between items-center border-b border-gray-200 dark:border-white/5">
            <div class="flex items-center gap-4">
                <button onclick="toggleSidebar()" class="lg:hidden p-2 rounded-lg bg-gray-100 dark:bg-dark-800 text-gray-600 dark:text-gray-300 hover:text-gold-500 transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
                <h1 id="page-title" class="text-xl md:text-2xl font-serif font-bold dark:text-white">Fleet & Bookings</h1>
            </div>
            <button onclick="toggleTheme()" class="p-2.5 rounded-full bg-gray-100 dark:bg-dark-800 text-gray-600 dark:text-gold-400 hover:shadow-lg hover:shadow-gold-500/20 transition-all duration-300 group">
                <svg class="w-5 h-5 hidden dark:block group-hover:rotate-90 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                <svg class="w-5 h-5 block dark:hidden group-hover:-rotate-12 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
            </button>
        </header>

        <div class="flex-1 overflow-y-auto p-6 md:p-8 pb-24">
            
            <!-- ========================================== -->
            <!-- TAB 1: FLEET & BOOKINGS -->
            <!-- ========================================== -->
            <div id="tab-fleet" class="tab-content active space-y-8">
                
                <!-- Add Vehicle Form -->
                <div class="glass-panel rounded-2xl p-6 md:p-8 shadow-xl fade-in-up">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-8 h-8 rounded-lg bg-gold-500/20 flex items-center justify-center text-gold-500">🚗</div>
                        <h2 class="text-xl font-serif font-bold dark:text-white">Add New Vehicle</h2>
                    </div>
                    <form action="/admin/vehicles" method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-1"><label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Vehicle Name</label><input type="text" name="name" required class="w-full bg-white dark:bg-dark-800 border border-gray-200 dark:border-gray-700 rounded-xl p-3 text-gray-800 dark:text-white focus:ring-2 focus:ring-gold-500 outline-none shadow-inner"></div>
                        <div class="space-y-1"><label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Category</label><select name="category" required class="w-full bg-white dark:bg-dark-800 border border-gray-200 dark:border-gray-700 rounded-xl p-3 text-gray-800 dark:text-white focus:ring-2 focus:ring-gold-500 outline-none shadow-inner appearance-none"><option value="Sedan">Sedan</option><option value="SUV">SUV</option><option value="Van">Van</option><option value="Minivan">Minivan</option><option value="Limousine">Limousine</option></select></div>
                        <div class="space-y-1"><label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Passengers</label><input type="number" name="passengers" min="1" required class="w-full bg-white dark:bg-dark-800 border border-gray-200 dark:border-gray-700 rounded-xl p-3 text-gray-800 dark:text-white focus:ring-2 focus:ring-gold-500 outline-none shadow-inner"></div>
                        <div class="space-y-1"><label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Luggage Capacity</label><input type="number" name="luggage" min="0" required class="w-full bg-white dark:bg-dark-800 border border-gray-200 dark:border-gray-700 rounded-xl p-3 text-gray-800 dark:text-white focus:ring-2 focus:ring-gold-500 outline-none shadow-inner"></div>
                        <div class="md:col-span-2 space-y-1"><label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Vehicle Image</label><input type="file" name="image" accept="image/*" required class="w-full bg-gray-50 dark:bg-dark-800/50 border border-dashed border-gray-300 dark:border-gray-600 rounded-xl p-4 text-gray-800 dark:text-gray-300 focus:ring-2 focus:ring-gold-500 outline-none file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-gold-500/10 file:text-gold-600 dark:file:text-gold-400 cursor-pointer"></div>
                        <div class="md:col-span-2 space-y-1"><label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Description (English)</label><textarea name="desc_en" required rows="2" class="w-full bg-white dark:bg-dark-800 border border-gray-200 dark:border-gray-700 rounded-xl p-3 text-gray-800 dark:text-white focus:ring-2 focus:ring-gold-500 outline-none shadow-inner resize-none"></textarea></div>
                        <div class="md:col-span-2 space-y-1"><label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Description (Arabic)</label><textarea name="desc_ar" required rows="2" class="w-full bg-white dark:bg-dark-800 border border-gray-200 dark:border-gray-700 rounded-xl p-3 text-gray-800 dark:text-white focus:ring-2 focus:ring-gold-500 outline-none shadow-inner resize-none text-right" dir="rtl"></textarea></div>
                        <div class="md:col-span-2 pt-4"><button type="submit" class="bg-gradient-to-r from-gold-600 via-gold-500 to-gold-400 text-black font-bold px-8 py-3.5 rounded-xl hover:shadow-lg hover:shadow-gold-500/40 hover:-translate-y-0.5 transition-all duration-300 uppercase tracking-widest text-sm">Add to Fleet</button></div>
                    </form>
                </div>

                <!-- Bookings Table -->
                <div class="glass-panel rounded-2xl shadow-xl overflow-hidden fade-in-up delay-100">
                    <div class="p-6 border-b border-gray-200 dark:border-white/5 flex items-center gap-3 bg-white/50 dark:bg-dark-800/50">
                        <div class="w-8 h-8 rounded-lg bg-gold-500/20 flex items-center justify-center text-gold-500">📅</div>
                        <h2 class="text-xl font-serif font-bold dark:text-white">Recent Bookings</h2>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700/50">
                            <thead class="bg-gray-50/50 dark:
bg-dark-800/50">
                                <tr>
                                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Trip Details</th>
                                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Customer</th>
                                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Route</th>
                                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
                                    <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200 dark:divide-gray-700/50 bg-white/30 dark:bg-transparent">
                                <% if (bookings.length === 0) { %>
                                    <tr><td colspan="5" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400 font-medium">No bookings found.</td></tr>
                                <% } %>
                                <% bookings.forEach(booking => { %>
                                <tr class="hover:bg-gray-50/80 dark:hover:bg-dark-800/50 transition-colors duration-200 group">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="text-sm font-bold text-gold-600 dark:text-gold-400 mb-1"><%= booking.trip_num %></div>
                                        <div class="text-xs text-gray-500 dark:text-gray-400"><%= booking.date %> | <%= booking.time %></div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="text-sm font-bold text-gray-900 dark:text-white"><%= booking.customer_name %></div>
                                        <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">📞 <%= booking.customer_phone %></div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-dark-700 text-gray-800 dark:text-gray-300 mb-2 border border-gray-200 dark:border-gray-600"><%= booking.trip_type || 'Standard' %></span>
                                        <div class="text-sm text-gray-600 dark:text-gray-300"><span class="font-semibold text-gray-900 dark:text-gray-200">From:</span> <%= booking.departure %></div>
                                        <div class="text-sm text-gray-600 dark:text-gray-300 mt-0.5"><span class="font-semibold text-gray-900 dark:text-gray-200">To:</span> <%= booking.destination %></div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <form action="/admin/bookings/status/<%= booking.id %>" method="POST">
                                            <% 
                                                const status = booking.status || 'Pending';
                                                let colorClass = 'bg-yellow-100 text-yellow-800 border-yellow-200 dark:bg-yellow-900/30 dark:text-yellow-400 dark:border-yellow-800/50';
                                                if (status === 'Confirmed') colorClass = 'bg-blue-100 text-blue-800 border-blue-200 dark:bg-blue-900/30 dark:text-blue-400 dark:border-blue-800/50';
                                                if (status === 'Completed') colorClass = 'bg-green-100 text-green-800 border-green-200 dark:bg-green-900/30 dark:text-green-400 dark:border-green-800/50';
                                                if (status === 'Cancelled') colorClass = 'bg-red-100 text-red-800 border-red-200 dark:bg-red-900/30 dark:text-red-400 dark:border-red-800/50';
                                            %>
                                            <select name="status" onchange="this.form.submit()" class="text-xs font-bold rounded-full px-4 py-1.5 border cursor-pointer focus:outline-none focus:ring-2 focus:ring-gold-500 transition-all appearance-none text-center shadow-sm <%= colorClass %>">
                                                <option value="Pending" <%= status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                                <option value="Confirmed" <%= status === 'Confirmed' ? 'selected' : '' %>>Confirmed</option>
                                                <option value="Completed" <%= status === 'Completed' ? 'selected' : '' %>>Completed</option>
                                                <option value="Cancelled" <%= status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                                            </select>
                                        </form>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                        <button type="button" onclick="openDeleteModal('/admin/bookings/delete/<%= booking.id %>', 'booking')" class="text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 bg-red-50 hover:bg-red-100 dark:bg-red-500/10 dark:hover:bg-red-500/20 px-4 py-2 rounded-xl transition-all duration-300 opacity-0 group-hover:opacity-100 focus:opacity-100">Delete</button>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Vehicles Table -->
                <div class="glass-panel rounded-2xl shadow-xl overflow-hidden fade-in-up delay-200">
                    <div class="p-6 border-b border-gray-200 dark:border-white/5 flex items-center gap-3 bg-white/50 dark:bg-dark-800/50">
                        <div class="w-8 h-8 rounded-lg bg-gold-500/20 flex items-center justify-center text-gold-500">🚘</div>
                        <h2 class="text-xl font-serif font-bold dark:text-white">Current Fleet</h2>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700/50">
                            <thead class="bg-gray-50/50 dark:bg-dark-800/50">
                                <tr>
                                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Vehicle</th>
                                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Category</th>
                                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Capacity</th>
                                    <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200 dark:divide-gray-700/50 bg-white/30 dark:bg-transparent">
                                <% if (vehicles.length === 0) { %>
                                    <tr><td colspan="4" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400 font-medium">No vehicles found. Add one above!</td></tr>
                                <% } %>
                                <% vehicles.forEach(vehicle => { %>
                                <tr class="hover:bg-gray-50/80 dark:hover:bg-dark-800/50 transition-colors duration-200 group">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center gap-4">
                                            <img src="<%= vehicle.image_url %>" alt="<%= vehicle.name %>" class="w-14 h-14 rounded-xl object-cover border border-gray-200 dark:border-gray-700 shadow-sm">
                                            <div class="text-sm font-bold text-gray-900 dark:text-white"><%= vehicle.name %></div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 dark:bg-dark-700 text-gray-800 dark:text-gray-300 border border-gray-200 dark:border-gray-600"><%= vehicle.category %></span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                                        👤 <%= vehicle.passengers %> | 🧳 <%= vehicle.luggage %>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                        <button type="button" onclick="openDeleteModal('/admin/vehicles/delete/<%= vehicle.id %>', 'vehicle')" class="text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 bg-red-50 hover:bg-red-100 dark:bg-red-500/10 dark:hover:bg-red-500/20 px-4 py-2 rounded-xl transition-all duration-300 opacity-0 group-hover:opacity-100 focus:opacity-100">Delete</button>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ========================================== -->
            <!-- TAB 2: ARTICLES & NEWS -->
            <!-- ========================================== -->
            <div id="tab-articles" class="tab-content space-y-8">
                
                <!-- Add Article Form -->
                <div class="glass-panel rounded-2xl p-6 md:p-8 shadow-xl fade-in-up">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-8 h-8 rounded-lg bg-gold-500/20 flex items-center justify-center text-gold-500">📝</div>
                        <h2 class="text-xl font-serif font-bold dark:text-white">Publish New Article</h2>
                    </div>
                    <form action="/admin/articles" method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-1 md:col-span-2">
                            <label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Article Title</label>
                            <input type="text" name="title" required class="w-full bg-white dark:bg-dark-800 border border-gray-200 dark:border-gray-700 rounded-xl p-3 text-gray-800 dark:text-white focus:ring-2 focus:ring-gold-500 outline-none shadow-inner">
                        </div>
                        <div class="space-y-1">
                            <label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Author Name</label>
                            <input type="text" name="author" value="Admin" required class="w-full bg-white dark:bg-dark-800 border border-gray-200 dark:border-gray-700 rounded-xl p-3 text-gray-800 dark:text-white focus:ring-2 focus:ring-gold-500 outline-none shadow-inner">
                        </div>
                        <div class="space-y-1">
                            <label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Cover Image</label>
                            <input type="file" name="image" accept="image/*" class="w-full bg-gray-50 dark:bg-dark-800/50 border border-dashed border-gray-300 dark:border-gray-600 rounded-xl p-3 text-gray-800 dark:text-gray-300 focus:ring-2 focus:ring-gold-500 outline-none file:mr-4 file:py-1.5 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-semibold file:bg-gold-500/10 file:text-gold-600 dark:file:text-gold-400 cursor-pointer">
                        </div>
                        <div class="md:col-span-2 space-y-1">
                            <label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Article Content</label>
                            <textarea name="content" required rows="6" class="w-full bg-white dark:bg-dark-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 text-gray-800 dark:text-white focus:ring-2 focus:ring-gold-500 outline-none shadow-inner resize-y"></textarea>
                        </div>
                        <div class="md:col-span-2 pt-4">
                            <button type="submit" class="bg-gradient-to-r from-gold-600 via-gold-500 to-gold-400 text-black font-bold px-8 py-3.5 rounded-xl hover:shadow-lg hover:shadow-gold-500/40 hover:-translate-y-0.5 transition-all duration-300 uppercase tracking-widest text-sm">Publish Article</button>
                        </div>
                    </form>
                </div>

                <!-- Articles Table -->
                <div class="glass-panel rounded-2xl shadow-xl overflow-hidden fade-in-up delay-100">
                    <div class="p-6 border-b border-gray-200 dark:border-white/5 flex items-center gap-3 bg-white/50 dark:bg-dark-800/50">
                        <div class="w-8 h-8 rounded-lg bg-gold-500/20 flex items-center justify-center text-gold-500">📰</div>
                        <h2 class="text-xl font-serif font-bold dark:text-white">Published Articles</h2>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700/50">
                            <thead class="bg-gray-50/50 dark:bg-dark-800/50">
                                <tr>
                                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Article</th>
                                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Author</th>
                                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Date Published</th>
                                    <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200 dark:divide-gray-700/50 bg-white/30 dark:bg-transparent">
                                <% if (!articles || articles.length === 0) { %>
                                    <tr><td colspan="4" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400 font-medium">No articles published yet.</td></tr>
                                <% } else { %>
                                    <% articles.forEach(article => { %>
                                    <tr class="hover:bg-gray-50/80 dark:hover:bg-dark-800/50 transition-colors duration-200 group">
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="flex items-center gap-4">
                                                <img src="<%= article.image_url %>" alt="Cover" class="w-16 h-12 rounded-lg object-cover border border-gray-200 dark:border-gray-700 shadow-sm">
                                                <div class="text-sm font-bold text-gray-900 dark:text-white truncate max-w-xs"><%= article.title %></div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-300 font-medium">
                                            <%= article.author %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                                            <%= new Date(article.created_at).toLocaleDateString() %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                            <button type="button" onclick="openDeleteModal('/admin/articles/delete/<%= article.id %>', 'article')" class="text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 bg-red-50 hover:bg-red-100 dark:bg-red-500/10 dark:hover:bg-red-500/20 px-4 py-2 rounded-xl transition-all duration-300 opacity-0 group-hover:opacity-100 focus:opacity-100">Delete</button>
                                        </td>
                                    </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <!-- DELETE CONFIRMATION MODAL -->
    <div id="deleteModal" class="fixed inset-0 z-[60] hidden flex items-center justify-center bg-black/60 backdrop-blur-md transition-opacity duration-300 opacity-0">
        <div id="deleteModalContent" class="glass-panel rounded-3xl shadow-2xl p-8 w-full max-w-sm transform transition-all duration-300 scale-95 opacity-0 border border-white/10">
            <div class="flex items-center justify-center w-16 h-16 mx-auto bg-red-500/10 rounded-full mb-6 border border-red-500/20">
                <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <h3 class="text-2xl font-serif font-bold text-center text-gray-900 dark:text-white mb-2">Confirm Deletion</h3>
            <p id="deleteModalText" class="text-sm text-gray-500 dark:text-gray-400 text-center mb-8">Are you sure you want to delete this item? This action cannot be undone.</p>
            <div class="flex justify-center gap-4">
                <button type="button" onclick="closeDeleteModal()" class="px-6 py-3 bg-gray-100 dark:bg-dark-800 text-gray-800 dark:text-gray-200 rounded-xl font-semibold hover:bg-gray-200 dark:hover:bg-dark-700 transition-colors w-1/2">Cancel</button>
                <form id="confirmDeleteForm" method="POST" action="" class="w-1/2">
                    <button type="submit" class="w-full px-6 py-3 bg-red-600 text-white rounded-xl font-semibold hover:bg-red-700 transition-colors shadow-lg shadow-red-600/30">Delete</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script>
        // --- Tab Switching Logic ---
        function switchTab(tabId) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });
            
            // Reset all buttons
            document.getElementById('tab-btn-fleet').className = "w-full flex items-center gap-3 px-4 py-3 rounded-xl text-gray-600 dark:text-gray-400 font-medium hover:bg-gray-100 dark:hover:bg-white/5 transition-all text-left";
            document.getElementById('tab-btn-articles').className = "w-full flex items-center gap-3 px-4 py-3 rounded-xl text-gray-600 dark:text-gray-400 font-medium hover:bg-gray-100 dark:hover:bg-white/5 transition-all text-left";
            
            // Show active tab
            document.getElementById('tab-' + tabId).classList.add('active');
            
            // Highlight active button
            document.getElementById('tab-btn-' + tabId).className = "w-full flex items-center gap-3 px-4 py-3 rounded-xl bg-gold-500/10 text-gold-600 dark:text-gold-400 font-medium border border-gold-500/20 transition-all text-left";
            
            // Update Page Title
            document.getElementById('page-title').innerText = tabId === 'fleet' ? 'Fleet & Bookings' : 'Articles & News';

            // Close sidebar on mobile after clicking
            if(window.innerWidth < 1024) {
                toggleSidebar();
            }
        }

        // --- Theme Toggle Logic ---
        function toggleTheme() {
            const html = document.documentElement;
            if (html.classList.contains('dark')) {
                html.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                html.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
        }

        if (localStorage.getItem('theme') === 'light') {
            document.documentElement.classList.remove('dark');
        } else {
            document.documentElement.classList.add('dark');
        }

        // --- Sidebar Toggle Logic (Mobile) ---
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('mobileOverlay');
            
            if (sidebar.classList.contains('-translate-x-full')) {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.remove('opacity-0'), 10);
            } else {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('opacity-0');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }
        }

        // --- Modal Logic ---
        function openDeleteModal(actionUrl, itemType) {
            const modal = document.getElementById('deleteModal');
            const modalContent = document.getElementById('deleteModalContent');
            const form = document.getElementById('confirmDeleteForm');
            const text = document.getElementById('deleteModalText');

            form.action = actionUrl;
            text.innerText = `Are you sure you want to delete this ${itemType}? This action cannot be undone.`;
            
            modal.classList.remove('hidden');
            void modal.offsetWidth; // Trigger reflow
            
            modal.classList.remove('opacity-0');
            modalContent.classList.remove('scale-95', 'opacity-0');
            modalContent.classList.add('scale-100', 'opacity-100');
        }

        function closeDeleteModal() {
            const modal = document.getElementById('deleteModal');
            const modalContent = document.getElementById('deleteModalContent');

            modalContent.classList.remove('scale-100', 'opacity-100');
            modalContent.classList.add('scale-95', 'opacity-0');
            modal.classList.add('opacity-0');
            
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        }

        document.getElementById('deleteModal').addEventListener('click', function(e) {
            if (e.target === this) closeDeleteModal();
        });
    </script>
</body>
</html>
